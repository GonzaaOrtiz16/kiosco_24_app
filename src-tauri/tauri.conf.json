{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HMS Kiosco 24hs",
  "version": "1.0.0",
  "identifier": "com.hms24.kiosco",
  "build": {
    "frontendDist": "https://kiosco-24-app.vercel.app/",
    "devUrl": "https://kiosco-24-app.vercel.app/",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "HMS Kiosco 24hs",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' https://kiosco-24-app.vercel.app; img-src 'self' https://* data:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://* wss://*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}